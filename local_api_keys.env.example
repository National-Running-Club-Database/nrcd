# Copy to local_api_keys.env (gitignored) and fill in your keys for live API tests.
#
#   cp local_api_keys.env.example local_api_keys.env
#
# Run live tests (skipped automatically if the file is missing or keys are empty):
#
#   pip install -e ".[dev,apis]"
#   pytest -m live_api -v
#
# You can also export the same variables in your shell instead of using this file.

# --- Required for live OpenWeather tests (geocode + meet altitude) ---
NRCD_OPENWEATHER_API_KEY=

# --- Optional: live historical weather tests (also needs TimeZoneDB) ---
NRCD_TIMEZONE_API_KEY=

# --- Optional: default ISO country for city,state,CC geocoding (default US) ---
# NRCD_GEOCODE_COUNTRY_SUFFIX=US

# --- Live test location / date (defaults below if omitted) ---
# Geocode + USGS altitude work on the OpenWeather free tier.
# Historical weather (timemachine) may require a paid OpenWeather plan.
#
# AQI history from OpenWeather starts on 2020-11-27 (see nrcd.enrich.AQI_HISTORY_AVAILABLE_FROM).
# Use event_date on or after that when testing weather/AQI backfill.
NRCD_LIVE_TEST_CITY=Notre Dame
NRCD_LIVE_TEST_STATE=IN
NRCD_LIVE_TEST_DATE=2024-10-12
NRCD_LIVE_TEST_TIME=10:00
